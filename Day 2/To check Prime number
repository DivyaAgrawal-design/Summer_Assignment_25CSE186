#include <stdio.h>

int main()
{
    int i,n,f=0;
    printf("enter your number");
    scanf("%d",&n);
    for(i=1;i<=n;i++){
        if(n%i==0){
            f=f+1;
        }
    }
    if(f==2){
        printf("number is prime");
    }
    else{
        printf("not a prime number");
    }

    return 0;
}
